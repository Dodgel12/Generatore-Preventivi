# .env.example - Copia questo file in .env e compila i valori

# Server
PORT=3000
SESSION_SECRET=cambia_questo_con_una_stringa_random_sicura_almeno_32_caratteri

# AI: Google Gemini Flash (gratuito)
# Ottieni la chiave su: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_inserisci_qui_la_tua_chiave

# Backup (percorso locale o NAS montato)
# Windows: Z:\Backup\preventivi
# Linux/Mac: /mnt/nas/backup
BACKUP_PATH=C:\Backup\preventivi

# Stampante WiFi (protocollo IPP)
# Trova l'IP nel router o pannello della stampante
# Poi apri http://<IP>:631 nel browser per vedere le stampanti disponibili
PRINTER_URL=http://192.168.1.50:631/printers/Nome_Stampante

# Dati azienda (appaiono nell'intestazione del PDF)
COMPANY_NAME=Antoni Gabriele
COMPANY_VAT=IT12345678901
COMPANY_ADDRESS=Via Roma 1, 00100 Roma
COMPANY_EMAIL=info@azienda.it
COMPANY_PHONE=+39 06 1234567
